# Normalize line endings to LF on commit, enforce UTF-8 for all text files
* text=auto eol=lf

# Explicit text files
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.toml  text eol=lf
*.env   text eol=lf

# Binary files — never diff or convert
*.png   binary
*.jpg   binary
*.svg   binary
